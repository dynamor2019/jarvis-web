[Unit]
Description=Jarvis Process Allowlist Guard
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/www/wwwroot/jarvis-web
Environment=ENFORCE=1
Environment=SCAN_INTERVAL=15
Environment=LOG_DIR=/www/wwwroot/jarvis-web/logs
ExecStart=/bin/bash /www/wwwroot/jarvis-web/scripts/process-allowlist-guard.sh
Restart=always
RestartSec=3
KillMode=process

[Install]
WantedBy=multi-user.target
