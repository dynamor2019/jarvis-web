{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/store/layout,_N_T_/store/mock/layout,_N_T_/store/mock/page,_N_T_/store/mock"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/store/mock/__PAGE__",
    "/store/mock",
    "/store",
    "/_index",
    "/_head"
  ]
}