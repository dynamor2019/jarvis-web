// Jarvis йҸҒзүҲеөҒжҗҙж’ҙДҒйҚЁ?
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// йҗўг„Ұеҹӣзҗӣ?
model User {
  id           String  @id @default(uuid())
  email        String  @unique
  username     String  @unique
  password     String
  name         String?
  avatar       String?
  role         String  @default("user") // 'user' | 'admin'
  balance      Float   @default(0) // жөЈж¬“о–Ӯй”ӣе ңжұүе§ҳжҲқз«өй”ӣ?
  tokenBalance Int     @default(0) // TokenдҪҷйўқ
  trafficTokenBalance Int @default(0) // жөҒйҮҸ Token дҪҷйўқ
  subscriptionTokenBalance Int @default(0) // и®ўйҳ… Token дҪҷйўқ
  totalSpent   Float   @default(0)
  isActive     Boolean @default(true)

  // йҗўг„Ұеҹӣз»«иҜІзҖ·йҸҚеӣӘзҳ‘
  userType String @default("real") // 'real' | 'virtual' - йҗӘзҶ·з–„йҗўг„Ұеҹӣ/й“Ҹж°ӯе«ҷйҗўг„Ұеҹӣ

  // йҗўг„ҰеҹӣйҗўиҜІе„ҡ - йҗўг„Өз°¬зјҒзҶ»о…ёйҚңеұҪз•ҫйҚҡжҲһеё№йӘһ?
  age        Int? // йӘһж’®з·һ
  gender     String? // йҺ¬СғеҹҶ: 'male' | 'female' | 'other'
  profession String? // ж¶“ж’Із¬ҹ/й‘ұеұјз¬ҹ
  industry   String? // зҗӣеұјз¬ҹ
  education  String? // зҖӣп№Җе·»: 'high_school' | 'bachelor' | 'master' | 'doctor' | 'other'
  school     String? // зҒҸиҫ«оҮ°й—„гҲЎзүҺ

  // йҚҰжқҝжҪғж·Үв„ғдј…
  country  String? @default("ж¶“о…һжө—") // йҚҘи—үоҶҚ
  province String? // йҗӘдҪ·е”Ө
  city     String? // йҚ©еәЎз«¶
  address  String? // з’ҮпёҫзІҸйҚҰжқҝжҪғ

  // й‘ұж—ӮйғҙйҸӮз‘°зҙЎ
  phone  String? // йҺөе¬«жәҖйҚҷ?
  wechat String? // еҜ°оҶ»дҝҠйҚҷ?
  qq     String? // QQйҚҷ?

  // жөЈи·Ёж•ӨйҚӢеҝ“гӮҪ
  preferredLanguage String? @default("zh-CN") // йҚӢеҝ“гӮҪз’Үо…Ўв–Ҳ
  timezone          String? @default("Asia/Shanghai") // йҸғи·әе°Ҝ

  // й’Җгғ©ж”ўйҸҚеӣ©о„·
  tags         String? // JSONйҸҒжү®зІҚзҖӣжҘғоғҒж¶“иҜ§зҙқжҝЎ? ["зҖӣпёҫж•“", "з’ҒзғҳжһғйҚҗж¬Һз¶”", "йҗһе——дјҗз»ү?]
  source       String? // йҗўг„ҰеҹӣйҸүгғҰз°®: 'organic' | 'referral' | 'ad' | 'social' | 'other'
  referralCode String? // йҺәг„Ёеҙҳйҗ®?
  referredBy   String? // йҺәг„ЁеҙҳжөңзҜ’D

  // зјҒзҶ»о…ёйҸҒзүҲеөҒ
  lastLoginAt DateTime? // йҸҲвӮ¬йҚҡеәЈж«ҘиӨ°жӣҹжӨӮй—Ӯ?
  loginCount  Int       @default(0) // йҗ§иҜІз¶ҚеЁҶв„ғжҡҹ
  registrationIp String? // еЁүг„Ҙе”ҪIPйҚҰжқҝжҪғ

  // йҺәе ҹжҪҲж·Үв„ғдј…
  licenseType     String    @default("trial") // 'trial' | 'subscription' | 'lifetime'
  licenseKey      String?   @unique // йҺәе ҹжҪҲйҗ®?
  subscriptionEnd DateTime? // з’ҒгҲӨж§„йҚ’зүҲж№ЎйҸғе •жЈҝ

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions    Transaction[]
  apiKeys         ApiKey[]
  usageRecords    UsageRecord[]
  systemDocs      SystemUserDoc[]
  orders          Order[]
  licenses        License[]
  featureRequests FeatureRequest[]
  featureVotes    FeatureVote[]
  featureComments FeatureComment[]
  referralCodes   ReferralCode[]
  subscriptionConfigs SubscriptionConfig[]
  featureUsageCounters UserFeatureUsage[]
  habitSnapshots UserHabitSnapshot[]
  supportTickets SupportTicket[]
  supportTicketReplies SupportTicketReply[] @relation("SupportTicketReplyAuthor")
}

// жҘ еІғзҳүйҗ®дҪҪгҖғ
model VerificationCode {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// жөңгӮҶж§—з’Ғжқҝз¶Қзҗӣ?
model Transaction {
  id            String   @id @default(uuid())
  userId        String
  type          String // 'recharge' | 'consume' | 'refund' | 'token_purchase'
  amount        Float
  tokens        Int? // TokenйҸҒдјҙеҷәй”ӣе қоӣ§йҸӢж»„ж§ёTokenжөңгӮҶж§—й”ӣ?
  balance       Float // жөңгӮҶж§—йҚҡеәқз¶‘жЈ°?
  tokenBalance  Int? // жөңгӮҶж§—йҚҡе¶өokenжөЈж¬“о–Ӯ
  description   String
  paymentMethod String? // 'alipay' | 'wechat' | 'balance'
  status        String   @default("pending") // 'pending' | 'completed' | 'failed'
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// APIзҖөе—ӣжҢңзҗӣ?
model ApiKey {
  id               String    @id @default(uuid())
  userId           String
  provider         String    @default("openai")
  key              String    @unique // APIзҖөе—ӣжҢңйҚқе қз¬Үй”ӣе ңз¬үзҖӣжЁәеҒҚйҚҳзҶ·оқҗзҖөе—ӣжҢңй”ӣ?
  modelType        String // еҰҜвҖізҖ·з»«иҜІзҖ·й”ӣ?deepseek' | 'kimi' | 'qwen' | 'doubao' | 'zhipu' | 'gemini' | 'gpt4'
  isActive         Boolean   @default(true)
  deviceFingerprint String?  // з’Ғжғ§оҳ¬йҺёеӣ©жұ—й”ӣе қеҪІй–«еӨӣзҙқйҗўг„Өз°¬з’Ғжғ§оҳ¬зјҒжҲқз•ҫй”ӣ?
  usageCount       Int       @default(0) // жөЈи·Ёж•ӨеЁҶв„ғжҡҹ
  lastUsedAt       DateTime? // йҸҲвӮ¬йҚҡеәқеЁҮйҗўг„ҰжӨӮй—Ӯ?
  expiresAt        DateTime // жқ©еӣЁж№ЎйҸғе •жЈҝ
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageRecords UsageRecord[]
  subscriptionConfig SubscriptionConfig?

  @@index([userId])
  @@index([key])
  @@index([isActive])
  @@index([expiresAt])
}

// жөЈи·Ёж•Өз’Ғжқҝз¶Қзҗӣ?
model UsageRecord {
  id        String   @id @default(uuid())
  userId    String
  apiKeyId  String?  // йҚҸе® д»ҲйҗЁеҮҷPIзҖөе—ӣжҢңID
  model     String // 'gpt-4' | 'gemini-pro' з»ӣ?
  tokens    Int
  cost      Float
  operation String // 'rewrite' | 'continue' | 'summarize' з»ӣ?
  endpoint  String?  // APIз»”оҲңеҒЈ
  responseTime Int? // йҚқе¶…з°ІйҸғе •жЈҝй”ӣе ҹоҮ з»үжҺһзҙҡ
  status    String   @default("success") // 'success' | 'failed' | 'rate_limited'
  errorMsg  String?  // й–ҝж¬’оҮӨж·Үв„ғдј…
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([status])
}

// Per-user feature click counters (aggregated by feature name)
model UserFeatureUsage {
  id        String   @id @default(uuid())
  userId    String
  feature   String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature])
  @@index([feature])
  @@index([count])
}

// Per-user/per-client latest habit snapshot for dashboard analytics
model UserHabitSnapshot {
  id                    String   @id @default(uuid())
  userId                String
  clientId              String
  tokenConsumed         Int      @default(0)
  tokenRemaining        Int      @default(0)
  trafficRemaining      Int      @default(0)
  subscriptionRemaining Int      @default(0)
  lastSyncedAt          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId])
  @@index([lastSyncedAt])
}

// з»ҜиҚӨзІәйҗўзҶёеһҡйҗўг„ҰеҹӣйҸӮеӣЁгҖӮй”ӣеңЎongoDBжӨӢеәўзүёйҸӮеӣЁгҖӮзјҒж’ҙзҖҜзҖӣжЁәеҒҚйҚҰ?JSON зҖӣжҘҒоҶҢй”ӣ?
model SystemUserDoc {
  id              String   @id @default(uuid())
  userId          String?  @unique // йҗӘзҶ·з–„йҗ§иҜІз¶Қйҗўг„ҰеҹӣйҚҷоҲҡеҸ§й‘ұ?
  sourceType      String // 'system_generated' | 'real_user'
  gender          String // 'male' | 'female'
  age             Int
  provinceCode    String // GB/T 2260 зҗӣеұҫж–ӮйҚ–иҪ°е”¬йҗ®дҫҠзҙҷйҗӘдҪәйӘҮй”ӣ?
  industryCode    String // зҗӣеұјз¬ҹжө пҪҮзҲңй”ӣе ЈеҡңзҖ№ж°«з®ҹж¶“з»ҳзҘҰзҗӣеұјз¬ҹзјӮж «зҲңй”ӣ?
  majorCode       String // ж¶“ж’Із¬ҹжө пҪҮзҲңй”ӣе ЈеҡңзҖ№ж°«з®ҹ100ж¶“оҒғз¬“ж¶“ж°ұзҙӘйҗ®дҫҠзҙҡ
  accessLevel     String? // 'full' з»ӣ?
  tokenReward     Int      @default(0)
  profileComplete Boolean  @default(false)
  createTime      DateTime @default(now())
  dataVersion     Int      @default(1)
  doc             String // зҖ№еұҫжҡЈйҸӮеӣЁгҖӮзҖӣжЁәеҒҚй”ӣеңЎongoDBйҸӮеӣЁгҖӮзјҒж’ҙзҖҜй”ӣ?
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sourceType])
  @@index([provinceCode])
  @@index([industryCode])
  @@index([majorCode])
  @@index([createTime])
}

// з’ҒгҲ еҙҹзҗӣ?
model Order {
  id            String    @id @default(uuid())
  userId        String
  orderNo       String    @unique // з’ҒгҲ еҙҹйҚҷ?
  orderType     String // 'lifetime' | 'subscription' | 'token_pack'
  productName   String // жөңСғжҗ§йҚҡе¶ҮРһ
  amount        Float // й–ІжҲҰо–Ӯ
  tokens        Int? // TokenйҸҒдјҙеҷәй”ӣе қоӣ§йҸӢж»„ж§ёTokenз’ҒгҲ еҙҹй”ӣ?
  duration      Int? // з’ҒгҲӨж§„йҸғе •жҡұй”ӣе ҹж№Җй”ӣ?
  modelType     String? // й–«еӨӢе«ЁйҗЁеҮҷIеҰҜвҖізҖ·з»«иҜІзҖ·
  status        String    @default("pending") // 'pending' | 'paid' | 'cancelled' | 'refunded'
  paymentMethod String? // 'alipay' | 'wechat'
  paymentTime   DateTime? // йҸҖоҲҷзІҜйҸғе •жЈҝ
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionConfig SubscriptionConfig?

  @@index([userId])
  @@index([orderNo])
  @@index([status])
  @@index([createdAt])
}

// йҺәе ҹжҪҲзҗӣ?
model License {
  id          String    @id @default(uuid())
  userId      String
  licenseKey  String    @unique // йҺәе ҹжҪҲйҗ®?
  licenseType String // 'lifetime_personal' | 'lifetime_pro' | 'subscription'
  status      String    @default("active") // 'active' | 'expired' | 'revoked'
  activatedAt DateTime? // е©өвӮ¬еЁІз»ҳжӨӮй—Ӯ?
  expiresAt   DateTime? // жқ©еӣЁж№ЎйҸғе •жЈҝй”ӣе Јо…№й—ғе‘Ҝеў—й”ӣ?
  deviceId    String? // з’Ғжғ§оҳ¬IDй”ӣе Ҙж§»е§қгҲ оҳҝз’Ғжғ§оҳ¬жөЈи·Ёж•Өй”ӣ?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([licenseKey])
  @@index([status])
}

// APIе§№зҠ»еҺӨзјғоҶҝгҖғ
model ApiPool {
  id               String   @id @default(uuid())
  provider         String // 'openai' | 'claude' | 'gemini' | 'doubao'
  apiKey           String // йҚ”зҠІзҳ‘зҖӣжЁәеҒҚ
  model            String // еҰҜвҖізҖ·йҚҡе¶ҮРһ
  costPer1kTokens  Float // йҺҙж„ӯж№°жө еҮӨзҙҷе§Јеҝ“еҙҲTokenй”ӣ?
  pricePer1kTokens Float // йҚһоҶ»зҺҜй”ӣе ҹзҳЎйҚ—еғ’okenй”ӣ?
  dailyLimit       Int      @default(1000000) // е§Јеҝ”жЈ©й—„ж„°о–Ӯ
  usedToday        Int      @default(0) // жө е©ғжЈ©е®ёиҢ¬ж•Ө
  isActive         Boolean  @default(true)
  priority         Int      @default(0) // жөјжЁәеҺӣз»ҫСҚзҙҷйҸҒжқҝз“§з“’е©ӮгҒҮз“’е©ҒзҙӯйҚҸе ¬зҙҡ
  lastResetDate    DateTime @default(now()) // ж¶“е©ғоӮјй–Іе¶Үз–ҶйҸғгғҰж№Ў
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([provider])
  @@index([isActive])
  @@index([priority])
}


// й—ҮвӮ¬е§№еӮҡз«¶йҚҰ?- йҚ”зҶ»е…ҳз’Үй”Ӣзң°
model FeatureRequest {
  id          String @id @default(uuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // 'community' (жөјжҘҒж№ңйҺөвӮ¬иӨ°? йҺҙ?'premium' (жҘӮжЁјйӘҮзҖ№ж°¬еҹ—)
  title       String
  description String // з’ҮпёҫзІҸйҺ»еҝҡе Ә
  category    String // 'ai', 'format', 'theme', 'plugin', 'other'
  status      String @default("pending") // 'pending', 'in_progress', 'completed', 'rejected'
  priority    Int    @default(0) // жөјжЁәеҺӣз»ҫСғеһҺйҸҒ?

  // жөјжҘҒж№ңйҺөвӮ¬иӨ°жҺ”жөүйҚҸ?
  upvotes Int @default(0) // йҗҗзЎ…зҰҗйҸҒ?

  // жҘӮжЁјйӘҮзҖ№ж°¬еҹ—йҗ©зЁҝеҸ§
  bounty Float   @default(0) // йҺ®о„ғзҘ»й–ІжҲҰо–Ӯ
  isPaid Boolean @default(false) // йҸ„оҲҡжғҒе®ёеҸүж•®жө ?

  // еҜ®вӮ¬йҚҷжҲ жөүйҚҸ?
  estimatedHours Int? // жЈ°еӢӘеҸҠе®ёгғҰжӨӮ
  actualHours    Int? // зҖ№зӮәжӘҜе®ёгғҰжӨӮ
  developerId    String? // еҜ®вӮ¬йҚҷжҲЈвӮ¬еҢўD
  completedAt    DateTime? // зҖ№еұҫеһҡйҸғе •жЈҝ

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes    FeatureVote[]
  comments FeatureComment[]

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([upvotes])
  @@index([bounty])
  @@index([createdAt])
}

// йҚ”зҶ»е…ҳз’Үй”Ӣзң°йҺ¶жӣ гӮЁ
model FeatureVote {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId String
  request   FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, requestId])
  @@index([requestId])
}

// йҚ”зҶ»е…ҳз’Үй”Ӣзң°з’ҮеӢ®оҶ‘
model FeatureComment {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId String
  request   FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  content   String // з’ҮеӢ®оҶ‘йҚҗе‘ӯоҶҗ
  createdAt DateTime       @default(now())

  @@index([requestId])
  @@index([createdAt])
}

// йҺәг„Ёеҙҳйҗ®дҪҪгҖғ
model ReferralCode {
  code      String    @id
  creatorId String
  creator   User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  uses      Int       @default(0)
  maxUses   Int       @default(1)
  usedAt    DateTime?
  usedById  String?
  source    String?
  note      String?
  createdAt DateTime  @default(now())

  @@index([creatorId])
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// AI Model Configuration
model AIModel {
  id          String   @id @default(cuid())
  name        String   // Display Name e.g. "Qwen 2.5 7B"
  value       String   // API Model String e.g. "Qwen/Qwen2.5-7B-Instruct"
  provider    String   // e.g. "siliconflow", "openai"
  tier        String   // "free", "pro", "premium"
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tier])
  @@index([isActive])
}

// TokenйҚ–е‘ҙеҺӨзјғоҶҝгҖғ
model TokenPackage {
  id          String   @id @default(uuid())
  name        String // йҚ–е‘ӯжӮ•з»ү?
  tokens      Int // TokenйҸҒдјҙеҷә
  bonusTokens Int      @default(0) // з’§зҠ»вӮ¬д№Җoken
  price       Float // жө й”Ӣзүё
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0) // йҺәжҺ‘з°ӯ
  
  // йҚҸе® д»ҲйҚҷоҲңж•ӨйҗЁеӢ¬ДҒйҚЁ?(йҚҷоҲһвӮ¬еӨӣзҙқжҝЎеӮӣзҒүйҸҢж„Әз°әйҚ–е‘ӯеҪ§й–Ҫе қоҮ®йҗ—з‘°з•ҫеҰҜвҖізҖ·)
  // жҝЎеӮӣзҒүж¶“иҷ№в”–й”ӣеұҪеһҜз’ҮгғҘеҜҳй–«еӮңж•ӨжөңеәўеўҚйҸҲ?Pro з»ҫС„ДҒйҚЁ?
  // models AIModel[] 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

// з’ҒгҲӨж§„й–°е¶Үз–Ҷзҗӣ?
model SubscriptionConfig {
  id               String   @id @default(uuid())
  userId           String
  orderId          String   @unique
  apiKeyId         String   @unique
  configId         String   @unique
  deviceFingerprint String
  encryptedData    String // йҚ”зҠІзҳ‘й–°е¶Үз–ҶйҸҒзүҲеөҒ
  expiresAt        DateTime // жқ©еӣЁж№ЎйҸғе •жЈҝ
  downloadCount    Int      @default(0) // ж¶“е¬ӯжөҮеЁҶв„ғжҡҹ
  lastDownloadedAt DateTime? // йҸҲвӮ¬йҚҡеәқз¬…жқһиҠҘжӨӮй—Ӯ?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([configId])
  @@index([expiresAt])
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  title       String
  category    String   @default("other") // payment | subscription | account | other
  content     String
  status      String   @default("pending") // pending | processing | resolved
  adminReply  String?
  repliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies SupportTicketReply[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SupportTicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  role      String   @default("admin") // user | admin
  content   String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation("SupportTicketReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
  @@index([createdAt])
}


