{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/store/layout,_N_T_/admin/store/page,_N_T_/admin/store"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/store/__PAGE__",
    "/admin/store",
    "/admin",
    "/_index",
    "/_head"
  ]
}