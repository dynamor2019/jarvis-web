                            >
                                鏌ョ湅瀹屾暣鑳藉姏
                            </a>
                        </div>

                        <div className="flex flex-wrap gap-2 pt-2 text-sm text-slate-600">
                            {USE_CASES.map((item) => (
                                <span key={item} className="rounded-full border border-slate-200 bg-white/80 px-3.5 py-1.5 shadow-sm">
                                    {item}
                                </span>
                            ))}
                        </div>
                    </div>

                    <div className="relative lg:pl-2 lg:pt-2">
                        <div className="absolute inset-5 -z-10 rounded-[40px] bg-gradient-to-br from-indigo-200/65 via-sky-100/40 to-fuchsia-200/45 blur-3xl" />
                        <div className="rounded-[34px] border border-slate-200/90 bg-white/94 p-5 shadow-[0_28px_90px_rgba(15,23,42,0.12)] backdrop-blur">
                            <div className="rounded-[24px] border border-indigo-100/70 bg-[linear-gradient(180deg,rgba(249,251,255,0.95),rgba(242,246,255,0.9))] px-4 py-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.9)]">
                                <p className="text-center text-[18px] font-semibold tracking-tight text-slate-800 md:text-[20px] lg:text-[22px] whitespace-nowrap">
                                    {activeScenario.tab}
                                </p>
                            </div>

                            <div className="mt-5 h-[470px] rounded-[26px] border border-indigo-100/80 bg-[linear-gradient(180deg,rgba(243,246,255,0.95),rgba(237,242,255,0.92))] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.95)]">
                                <div className={`flex h-full w-full gap-2 transition-all duration-700 ${playDirection < 0 ? 'flex-row-reverse' : ''}`}>
                                    {SCENARIOS.map((scenario, index) => {
                                        const isActive = index === scenarioIndex;
                                        return (
                                            <div
                                                key={scenario.tab}
                                                onClick={() => setScenarioIndex(index)}
                                                className={`relative cursor-pointer overflow-hidden rounded-[22px] border border-white/60 shadow-[0_10px_28px_rgba(79,70,229,0.12)] transition-all duration-700 ease-out ${
                                                    isActive ? 'min-w-[220px] flex-[1.8]' : 'min-w-[44px] flex-[0.42]'
                                                }`}
                                                style={{ background: RIBBON_COLORS[index % RIBBON_COLORS.length] }}
                                            >
                                                <div className="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.58),transparent_58%)]" />
                                                <div className="relative flex h-full flex-col items-center px-1 py-4">
                                                    <span
                                                        className={`[writing-mode:vertical-rl] [text-orientation:mixed] bg-[linear-gradient(180deg,#4f46e5_0%,#7c3aed_45%,#d946ef_100%)] bg-clip-text font-black tracking-[0.08em] text-transparent transition-all duration-700 ${
                                                            isActive ? 'text-[34px] leading-[1.05]' : 'text-[22px] leading-[1.12] opacity-85'
                                                        }`}
                                                        style={{ fontFamily: '"STKaiti","KaiTi","DFKai-SB","FangSong","Noto Serif SC",serif' }}
                                                    >
                                                        {scenario.tab}
                                                    </span>

                                                    {isActive && (
                                                        <div className="mt-auto w-full rounded-[16px] border border-white/75 bg-white/70 px-3 py-3 backdrop-blur-sm">
                                                            <p className="text-xs font-medium leading-6 text-slate-700 line-clamp-3">{scenario.prompt}</p>
                                                            <div className="mt-2 flex flex-wrap gap-1.5">
                                                                {scenario.outputTags.slice(0, 2).map((tag) => (
                                                                    <span key={tag} className="rounded-full bg-white/90 px-2 py-1 text-[11px] font-medium text-violet-700">
                                                                        {tag}
                                                                    </span>
                                                                ))}
                                                            </div>
                                                        </div>
                                                    )}
                                                </div>
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>

                            <div className="mt-5 rounded-[18px] border border-slate-200/90 bg-white/75 px-3 py-3">
                                <div className="flex items-center justify-end">
                                    <span className="text-xs font-medium text-slate-500">{scenarioIndex + 1}/{scenarioCount}</span>
                                </div>
