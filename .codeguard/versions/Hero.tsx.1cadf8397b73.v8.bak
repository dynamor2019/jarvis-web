                }
                @keyframes heroRainbowBorder {
                    0%, 19.99% { opacity: 0; }
                    20% { opacity: 0; }
                    24% { opacity: 1; }
                    70% { opacity: 1; }
                    75%, 100% { opacity: 1; }
                }
                .hero-rainbow-border::before,
                .hero-rainbow-border::after {
                    content: '';
                    position: absolute;
                    inset: -2px;
                    border-radius: 26px;
                    pointer-events: none;
                    opacity: 0;
                    animation: heroRainbowBorder 10s ease-in-out 0s 3 forwards;
                }
                .hero-rainbow-border::before {
