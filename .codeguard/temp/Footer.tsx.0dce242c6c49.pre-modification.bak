const finalSteps = [
    ['01', '选模型', '选择适合当天任务的 AI 能力'],
    ['02', '拿配置', '把权益和模型连接到本机'],
    ['03', '进 Word', '生成、润色、排版直接完成'],
    ['04', '可追踪', '订单、配置、错误状态都有反馈']
];

import { FormattedMessage } from 'react-intl';

function FooterTechAnimation() {
    const rootRef = useRef<HTMLDivElement>(null);
    const coreRef = useRef<HTMLDivElement>(null);

    useEffect(() => {
        const root = rootRef.current;
        if (!root || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const orbits = root.querySelectorAll('[data-orbit]');
        const particles = root.querySelectorAll('[data-particle]');
        const stars = root.querySelectorAll('[data-star]');

        animate(orbits, {
            rotate: (_, index) => index % 2 ? '-360deg' : '360deg',
            duration: (_, index) => 9800 + index * 1700,
            loop: true,
            ease: 'linear',
        });
        animate(particles, {
            scale: [0.72, 1.18, 0.72],
            opacity: [0.42, 1, 0.42],
            duration: 1800,
            delay: stagger(180),
            loop: true,
            ease: 'inOutSine',
        });
        animate(stars, {
            opacity: [0.16, 0.8, 0.16],
            scale: [0.8, 1.35, 0.8],
            duration: 2200,
            delay: stagger(95),
            loop: true,
            ease: 'inOutSine',
        });
        if (coreRef.current) {
            animate(coreRef.current, {
                scale: [0.94, 1.08, 0.94],
                boxShadow: [
                    '0 0 34px rgba(34,211,238,0.32)',
                    '0 0 72px rgba(217,70,239,0.42)',
                    '0 0 34px rgba(34,211,238,0.32)',
                ],
                duration: 2600,
                loop: true,
                ease: 'inOutSine',
            });
        }
    }, []);

    const handlePointerEnter = () => {
        const root = rootRef.current;
        if (!root) return;
        animate(root.querySelectorAll('[data-orbit]'), {
            scale: [1, 1.08],
            duration: 520,
            ease: 'outExpo',
        });
    };

    const handlePointerMove = (event: React.MouseEvent<HTMLDivElement>) => {
        const root = rootRef.current;
        const core = coreRef.current;
        if (!root || !core) return;
        const rect = root.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width - 0.5) * 18;
        const y = ((event.clientY - rect.top) / rect.height - 0.5) * 18;
        animate(core, {
            translateX: x,
            translateY: y,
            duration: 520,
            ease: 'outExpo',
        });
    };

    return (
        <div
            ref={rootRef}
            onMouseEnter={handlePointerEnter}
            onMouseMove={handlePointerMove}
            className="relative mb-8 overflow-hidden rounded-[34px] border border-cyan-200/14 bg-slate-950/46 p-4 shadow-[0_28px_90px_rgba(2,6,23,0.32)] backdrop-blur-2xl"
        >
            <div className="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(34,211,238,0.18),transparent_26%),radial-gradient(circle_at_20%_30%,rgba(236,72,153,0.12),transparent_28%),linear-gradient(135deg,rgba(15,23,42,0.58),rgba(2,6,23,0.9))]" />
            <div className="relative min-h-[260px] overflow-hidden rounded-[28px] border border-white/8">
                {Array.from({ length: 36 }).map((_, index) => (
                    <span
                        key={index}
                        data-star
                        className="absolute h-1 w-1 rounded-full bg-cyan-100/70"
                        style={{ left: `${(index * 23) % 96}%`, top: `${(index * 41) % 92}%` }}
                    />
                ))}
                <div className="absolute inset-0 flex items-center justify-center">
                    <div ref={coreRef} className="relative z-10 flex h-24 w-24 items-center justify-center rounded-full border border-cyan-100/30 bg-[radial-gradient(circle,rgba(34,211,238,0.95),rgba(79,70,229,0.56)_48%,rgba(2,6,23,0.18)_70%)]">
                        <span className="h-8 w-8 rounded-full bg-white/92 shadow-[0_0_28px_rgba(255,255,255,0.85)]" />
                    </div>
                    {[0, 1, 2, 3].map((item) => (
                        <div
                            key={item}
                            data-orbit
                            className="absolute rounded-full border border-cyan-100/18"
                            style={{
                                width: `${210 + item * 74}px`,
                                height: `${82 + item * 30}px`,
                                transform: `rotate(${item * 34}deg)`,
                            }}
                        >
                            <span
                                data-particle
                                className="absolute left-1/2 top-0 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-200 shadow-[0_0_28px_rgba(125,211,252,0.95)]"
                            />
                            <span
                                data-particle
                                className="absolute bottom-0 left-1/2 h-2.5 w-2.5 -translate-x-1/2 translate-y-1/2 rounded-full bg-fuchsia-300 shadow-[0_0_22px_rgba(240,171,252,0.85)]"
                            />
                        </div>
                    ))}
                </div>
                <div className="absolute bottom-5 left-5 rounded-full border border-cyan-200/18 bg-slate-950/48 px-4 py-2 text-xs font-semibold text-cyan-100 backdrop-blur-xl">
                    AI Orbit · 拖动鼠标扰动核心
                </div>
            </div>
        </div>
    );
}

export default function Footer() {
    return (
        <footer className="relative flex min-h-[calc(100vh-64px)] items-center overflow-hidden bg-[#0f172a] py-12 text-white">
            <div className="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_16%_22%,rgba(45,212,191,0.12),transparent_30%),radial-gradient(circle_at_82%_72%,rgba(99,102,241,0.13),transparent_34%)]" />
            <div className="container relative mx-auto px-4">
                <FooterTechAnimation />
                <div className="relative mb-10 overflow-hidden rounded-[34px] border border-cyan-200/14 bg-white/[0.045] p-6 shadow-[0_30px_100px_rgba(2,6,23,0.28)] backdrop-blur-xl md:p-8">
                    <img src="/assets/showcase/writing-flow.jpg" alt="" className="absolute inset-0 h-full w-full object-cover opacity-10 mix-blend-luminosity" />
                    <div className="absolute inset-0 bg-[linear-gradient(105deg,rgba(2,6,23,0.94),rgba(8,47,73,0.62),rgba(30,41,59,0.86))]" />
                    <div className="pointer-events-none absolute left-8 right-8 top-1/2 h-px bg-gradient-to-r from-transparent via-cyan-200/70 to-transparent" />
                    <div className="relative grid gap-7 md:grid-cols-[0.82fr_1.18fr] md:items-center">
                        <div>
                            <div className="mb-3 inline-flex rounded-full border border-cyan-200/20 bg-cyan-300/10 px-3 py-1 text-xs font-semibold text-cyan-100">从选择到成稿</div>
                            <h2 className="text-3xl font-black leading-tight md:text-4xl">
