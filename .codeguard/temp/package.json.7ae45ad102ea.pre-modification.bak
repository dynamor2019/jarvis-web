{
  "name": "jarvis-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "node -e \"const fs=require('fs'),path=require('path'),cp=require('child_process');fs.rmSync('.next_build',{recursive:true,force:true});const u=process.env.DATABASE_URL||'file:./prisma/jarvis.db';if(u.startsWith('file:./')){process.env.DATABASE_URL='file:'+path.resolve(u.slice(5));}const r=cp.spawnSync(process.platform==='win32'?'next.cmd':'next',['build'],{stdio:'inherit',env:process.env,shell:true});process.exit(r.status??1);\" && node scripts/copy-standalone-assets.js",
    "start": "node server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@icon-park/react": "^1.4.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-table": "^8.21.3",
    "alipay-sdk": "^4.14.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "echarts": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "next": "16.0.10",
    "nodemailer": "^7.0.11",
    "qrcode": "^1.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-intl": "^7.1.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "baseline-browser-mapping": "^2.9.19",
    "browserslist": "^4.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5"
  }
}
