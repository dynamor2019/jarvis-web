                                    <span className="text-sm font-black" style={{ color: module.color }}>0{index + 1}</span>
                                </div>
                                <h3 className="mb-4 text-xl font-bold text-slate-950"><FormattedMessage id={`functions.list.${index}.title`} defaultMessage={module.title} /></h3>
