'use client';

import Link from 'next/link';
import { useEffect, useState, Suspense } from 'react';
import { usePathname, useSearchParams } from 'next/navigation';
import { FormattedMessage } from 'react-intl';

export default function Navbar() {
    return (
        <Suspense fallback={<div className="h-16 bg-white/80 backdrop-blur-md fixed w-full z-50 top-0 border-b border-gray-100" />}>
            <NavbarContent />
        </Suspense>
    );
}

function NavbarContent() {
    const [isLoggedIn, setIsLoggedIn] = useState(false);
    const [isAdmin, setIsAdmin] = useState(false);
    const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
    const [scrolled, setScrolled] = useState(false);
    const pathname = usePathname();
    const searchParams = useSearchParams();
    const isWv = searchParams.get('wv') === '1';

    useEffect(() => {
        const checkNavbar = () => {
            try {
                // жҝ з”өе§·йҸҒжҗҒеҙ‘йҗҗе·®з„Ҫжҝһе—ҳжҢёз‘ҷп№ӮжӮ—й”қеәЎжһҹй–әе’ҒдәӘе§Ҡз»ҳжӢ…йҚӣе©ӮжҡҲй–ҪеҶӯдә¬з»ұжҺ”вӮ¬пҪҺеҒ„еЁҙоҶҪоҡҘйҗҗиҢ¬з®»зҖ№жӣҳеҠ‘йЎўж¶ҳвҳүеҰҜзЎ·зҙЎй—ӮеӮҷз·ҡеЁјСҮвҖҰйЎ“гҲЎв’”й–ёжӣЁеҒҖйҸӢ?window.location.search жҝ з”өе§·йҸҒжҗҒеҙ‘еЁ‘гҲ©ж•ӢжӨӨж’¶е–җйҚҷеҝ“Г№йҚҸе…јз¶‘з»ҫжғ§жҪЎйҸҢпј„д»Ұз’ҮжҸ’е§Һй—Ғе“„оғ„йҗ’п№ӮеҰөйҚ•оҲҡеҚіжҝЎгӮӮеҒ“еЁҙж»„е„іиһ–?replaceState й—ӮеӮҡеҖёйҚҠйЈҺзІҲжёҡвӮ¬йӘһж ӯо”•йҲ·ж°ӯжӨҪжҝЎиҲөеҫ„зҖЈоҒғж§җй—ӮдҫҖжҪ§иүҢй–әе‘®зӣҜйҺ·?                // next/navigation й—Ӯ?searchParams й—Ӯ?replaceState жҝ з”өе§·йҸҒжҗҒеҙ‘йҗҗе“„еһӮй–ёоӮЈжҙ–з» дјҙжҹҹй—ӮеҜёиҙ°й–әдҪёе«°йҸҢж¶ҳвҳүе©ҠеҶӘеҠ·жҝһеӯҳзІҢзјҚе©Үеј»й”ӣеӢӘжІӘйҗ еӣЁеҪғжҝ®жӣўжўәйҺјзӮІвӮ¬жӣ вӮ¬ж°«еҚіеҜ®е©ҡжӮўзҗӣвҖідәҫжҝһжҲһоҒӘйЎҸе—ҷз®”з‘ңж—Ҳеј»й”қеӨӢеҒ„й–ёжҝ„е„ійҗЈз”ёжў»йҚҘСҢжЁҖй–әеұҫзЁ–з» ж¶ўе№ҳй“ҸоӮўвӮ¬оҲһжўәе§№еӣ§еҰҪй–ёг„ҘжҪЎеҜ®е©ҡж•җйҚӣоҒ…ж–Җй—Ғжҗһе„®йҸ…ж»ҲеҙҡеЁ‘гҲЎеҖөйҗҹж¬Ҹе«ӯз»Ңи·Ёзҙ’зјҒжЁјз®һжҘ зӮҙзүһйҠҮж„°е№’е©өеӣЁж«Үй—ӮдҪ№еҜ§з»»еӮҡГәйҠҲеӨҠеҗ№й—Ғо„Җз§өйҲ·?
                const sp = typeof window !== 'undefined' ? new URLSearchParams(window.location.search) : searchParams;
                
                const wv = (sp?.get('wv') || '') === '1';
                const shouldHide = wv;

                const main = document.querySelector('main') as HTMLElement | null;
                if (main) main.style.paddingTop = shouldHide ? '0px' : '64px';
                // const navEl = document.getElementById('site-navbar') as HTMLElement | null;
                // if (navEl) navEl.style.display = shouldHide ? 'none' : '';
            } catch {}
        };

        checkNavbar();
        window.addEventListener('jarvis-url-change', checkNavbar);
        window.addEventListener('popstate', checkNavbar); // й—ӮеӮҡеҖёйҚҠйЈҺзІҲжёҡвӮ¬йӘһеӨҗж•“йҗҳеҶІж®һжҝЎгӮҸзөҪйҚҹоӮӨвӮ¬ж°¬оҳ°йҠҮеӢҜе№’йҚЎжӨҫеЈ•жҝЎзӮӘеҖӨжөңж»ҲеҙҜйҸүжҲ жҡҰй–№зғҳеһҹеҰІе ҹж…Ёе§—е ўзЁ»й–»еҝ“жЈқе§Ҡз»ҳжӢ…й“Ҹз‘°з¬Ўе©өоҶјп№ӨйЎӯеі°з•·йҸҮгҲ О§й–ёгғ‘еұҫо—Ўй–»зҶёзІҚеҰ«еҶЁоҮЈ?popstate
        
        return () => {
            window.removeEventListener('jarvis-url-change', checkNavbar);
            window.removeEventListener('popstate', checkNavbar);
        };
    }, [pathname, searchParams]);

    if (isWv) return null;

    useEffect(() => {
        const syncAuthState = () => {
            try {
                const token = localStorage.getItem('token');
                const raw = localStorage.getItem('user');
                let admin = false;
                if (raw) {
                    const user = JSON.parse(raw);
                    admin = user?.role === 'admin';
                }
                setIsLoggedIn(!!token);
                setIsAdmin(admin);
            } catch {
                setIsLoggedIn(false);
                setIsAdmin(false);
            }
        };

        syncAuthState();
        window.addEventListener('storage', syncAuthState);
        window.addEventListener('focus', syncAuthState);
        return () => {
            window.removeEventListener('storage', syncAuthState);
            window.removeEventListener('focus', syncAuthState);
        };
    }, [pathname]);
