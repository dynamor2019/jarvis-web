            navLinks.forEach((link) => {
                const element = link as HTMLElement;
                element.style.maxWidth = 'none';
                element.style.width = 'auto';
            });
        };
        
        // й—ӮеӮҷжөҮйЎ•СғГ№йҗ‘и—үзЈ»й–ҝжҝҶоҳҜзәҫеҪ’жҹЎе®ҘеәЎе№–з»ҫжғ§жҪЎйҸҢгӮ…Г№зҖЈоӮЈзҸ•йҗҺи§„жҙ–еҜ®еүҒжҚўе©өеӣ©зҜҖй–ёеұҫзІҢйЎЈиҷ№зҙ“жөЈе“„Рһй–ёеәўеЁҠйӘһеӨҗе№–жөЈе“Ҙо…әй—ҒжҢҺжЈҒйҠҶвӮ¬й–ёе¬«жҢ»з»—зҶјеҹҖйЎ’еӢӯеөҒйҗҺпҪҺе–—йҚҠй”Ӣз№ӣйҚ«зҶ·оҮңзјҒдҫҮеҒҠе§Ҡз»ҳз¬ҹйҲ§о„ҖоҹҮиӨ”йҸҒе¶Ҳз®ӣеЁ‘жЁјеҠҰеҰһгӮҶеё’зҖҡо„„жӮһйҚЁоӮ дәңй–№е“„з§ҙйЎ’ж»ҲжҹҹзҖөзЁҝРҘй–»?DOM й—ӮеӮҷжөҮйЎ•СғГ№йҗ‘и—үз® й–№жҚҗоҮ§з» зҶјжўҪйҚҘо„ҖОҰй–№зүҲжҫҳз»ҖеҶ©гҒ„йҸғеӣЁо—үеЁҙзҠөеҺ§йЎӘеҶ®еҰ¶йҚЎжҘғз‘Ёй–»еәўеҮ№йҚ“ж¶ҡеҲ’йҚ«гғҘзЈјй–»ж„¬оҮӯйҚҳоҒ…з№қйҗўйқӣРўзјҒз»ҳеёЎйҺ®й№ғжҗ№йЎҗзҠұз°»й—ҒеҶІжҗ«й”•гӮҶзҰҚжөјеӯҳз…ӣ?
        const timer = setTimeout(fixNavLinks, 100);
